{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI: reconcile",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/src/cli/index.ts",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "Debug Current Bun Test File",
      "type": "bun",
      "request": "launch",
      "program": "${file}",
      "runtimeArgs": ["test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
